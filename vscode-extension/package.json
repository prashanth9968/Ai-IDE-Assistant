{
  "name": "ai-ide-assistant",
  "displayName": "AI IDE Assistant",
  "description": "Real-time AI-powered Java code completions using Microsoft CodeBERT",
  "version": "1.0.0",
  "publisher": "prashanth9968",
  "repository": {
    "type": "git",
    "url": "https://github.com/prashanth9968/Ai-IDE-Assistant"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "java",
    "ai",
    "code completion",
    "codebert",
    "intellisense"
  ],
  "activationEvents": [
    "onLanguage:java"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-ide-assistant.analyzeJava",
        "title": "AI IDE Assistant: Analyze Java Code"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.5.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}